{
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": false,
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "resolveJsonModule": true,
