# Metro + Expo autolinking are fragile with pnpm's strict, symlinked layout.
# Hoist the RN/Expo ecosystem so Metro can resolve it (see plan §1, §7).
node-linker=hoisted
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=*@react-native*
public-hoist-pattern[]=*metro*
public-hoist-pattern[]=*heroui*
public-hoist-pattern[]=*uniwind*
strict-peer-dependencies=false
