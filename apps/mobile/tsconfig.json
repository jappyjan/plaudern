{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["react", "node"],
    "strict": true,
    "noEmit": true
  },
  "include": ["app/**/*", "src/**/*", "modules/**/*", "app.config.ts", ".expo/types/**/*.ts"],
  "exclude": ["node_modules"]
}
