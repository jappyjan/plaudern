{
  "name": "mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mobile",
  "projectType": "application",
  "tags": ["scope:mobile", "type:app"],
  "targets": {
    "start": {
      "executor": "nx:run-commands",
      "options": { "command": "expo start --dev-client", "cwd": "apps/mobile" }
    },
    "prebuild": {
      "executor": "nx:run-commands",
      "options": { "command": "expo prebuild --platform ios", "cwd": "apps/mobile" }
    },
    "prebuild-ios": {
      "executor": "nx:run-commands",
      "options": { "command": "expo prebuild --platform ios --no-install", "cwd": "apps/mobile" }
    },
    "prebuild-android": {
      "executor": "nx:run-commands",
      "options": { "command": "expo prebuild --platform android --no-install", "cwd": "apps/mobile" }
    },
    "run-ios": {
      "executor": "nx:run-commands",
      "options": { "command": "expo run:ios", "cwd": "apps/mobile" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p apps/mobile/tsconfig.json --noEmit" }
    }
  }
}
