# API the app talks to. Use a LAN-reachable host (not localhost) on a device.
EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

# Plaud dev-console credentials (used by the native SDK). Prefer EAS secrets.
PLAUD_CLIENT_ID=
PLAUD_CLIENT_SECRET=
EXPO_PUBLIC_PLAUD_CLIENT_ID=
EXPO_PUBLIC_PLAUD_CLIENT_SECRET=
