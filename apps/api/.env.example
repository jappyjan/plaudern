# --- Database ---
DATABASE_DRIVER=postgres
DATABASE_URL=postgres://plaudern:plaudern@localhost:5432/plaudern
# set true for quick local dev to auto-create schema; leave unset to run migrations
DATABASE_SYNCHRONIZE=false

# --- Object storage (MinIO in dev) ---
STORAGE_DRIVER=s3
# Internal endpoint used for server-side S3 operations.
S3_ENDPOINT=http://localhost:9000
# Endpoint baked into presigned URLs handed to clients. Set to a host reachable
# by the client (e.g. your LAN IP) when uploading from a phone/simulator.
# Falls back to S3_ENDPOINT when unset.
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=plaudern-inbox
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL=900

# --- Queue ---
QUEUE_DRIVER=bull
REDIS_URL=redis://localhost:6379

# --- Transcription ---
# elevenlabs = hosted ElevenLabs Scribe API (default)
# whisper    = self-hosted Whisper-compatible HTTP server (local-model tier —
#              audio never leaves your infra; required for sensitivity routing,
#              see ATT-662/ATT-687)
TRANSCRIPTION_PROVIDER=elevenlabs

# ElevenLabs Scribe (scribe_v2). Audio bytes are uploaded to ElevenLabs
# directly (we push, they never pull), so your storage stays private. API key
# from elevenlabs.io.
ELEVENLABS_API_KEY=
# Speech-to-text model. scribe_v1 is deprecated; use scribe_v2.
# ELEVENLABS_STT_MODEL=scribe_v2
# Base URL (override only for a proxy/self-hosted gateway).
# ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
# Tag non-speech sounds like (laughter) inline in the transcript.
# ELEVENLABS_TAG_AUDIO_EVENTS=false
# Overall request timeout and audio-download timeout (ms).
# ELEVENLABS_STT_TIMEOUT_MS=1800000
# ELEVENLABS_DOWNLOAD_TIMEOUT_MS=300000

# Local Whisper (only used when TRANSCRIPTION_PROVIDER=whisper). Point this at
# any server exposing the OpenAI-compatible `/v1/audio/transcriptions`
# endpoint — e.g. faster-whisper-server / speaches
# (https://github.com/speaches-ai/speaches) or whisper.cpp's built-in server.
# No model weights ship with this app; run the server yourself (see the
# commented `whisper` service in docker-compose.yml) and point WHISPER_BASE_URL
# at it. Most local servers need no API key.
# WHISPER_BASE_URL=http://localhost:8000/v1
# WHISPER_API_KEY=
# Must match a model the server has loaded; whisper.cpp servers generally
# ignore this field.
# WHISPER_MODEL=Systran/faster-whisper-small
# Overall request timeout and audio-download timeout (ms). Local CPU inference
# is often much slower than the hosted API, hence the higher default.
# WHISPER_TIMEOUT_MS=1200000
# WHISPER_DOWNLOAD_TIMEOUT_MS=300000

# --- AI summarization ---
# After a recording is transcribed and diarized, an LLM writes it a short
# descriptive title and a Markdown summary (with mermaid diagrams and clickable
# speaker mentions), picking a layout that fits the content. Any
# OpenAI-compatible /chat/completions endpoint works — cloud (DeepSeek, OpenAI,
# OpenRouter, ...) or self-hosted (Ollama, llama.cpp, ...).
#
# Cloud endpoints: leave SUMMARIZATION_API_KEY empty to disable summarization
# entirely (the pipeline step becomes a no-op and the UI just shows the
# transcript). Defaults target DeepSeek (deepseek-chat) — the cheapest capable
# option. For OpenAI use SUMMARIZATION_BASE_URL=https://api.openai.com/v1 and
# SUMMARIZATION_MODEL=gpt-4o-mini; OpenRouter, Together, Groq work the same way.
SUMMARIZATION_API_KEY=
# SUMMARIZATION_BASE_URL=https://api.deepseek.com/v1
# SUMMARIZATION_MODEL=deepseek-chat
# Overall request timeout (ms). Local CPU inference can be much slower than a
# hosted API — raise this for Ollama on modest hardware.
# SUMMARIZATION_TIMEOUT_MS=120000
#
# Local Ollama (the local-model tier, see ATT-662/ATT-687 — sensitive
# transcripts never leave your infra): Ollama's OpenAI-compatible endpoint
# needs no API key, so set SUMMARIZATION_ENABLED=true instead of a key, then
# point BASE_URL/MODEL at your Ollama instance. `ollama pull <model>` first.
# SUMMARIZATION_ENABLED=true
# SUMMARIZATION_BASE_URL=http://localhost:11434/v1
# SUMMARIZATION_MODEL=llama3.1
# SUMMARIZATION_TIMEOUT_MS=300000

# --- AI-provider audit log (JJ-42) ---
# Every call to an external AI provider (transcription, diarization, LLM,
# embeddings) is recorded per-user: which item, kind, provider, endpoint, byte
# size and a SHA-256 content hash. The payload itself is NEVER stored by default.
# Set AI_AUDIT_STORE_PAYLOAD=true to ALSO keep a truncated, redacted copy of each
# request payload for debugging — leave it unset (metadata-only) in production.
# AI_AUDIT_STORE_PAYLOAD=false

# --- Embeddings (semantic memory, ATT-659) ---
# After transcription (and summarization, when enabled) each recording gets
# chunked vector embeddings of its transcript + summary, stored in pgvector —
# the foundation for semantic search and memory chat. Any OpenAI-compatible
# /embeddings endpoint works. Leave everything below unset to disable the step.
#
# NOTE: DeepSeek has NO embeddings API (chat models only), so the DeepSeek
# summarization key CANNOT be reused here. For a no-extra-keys setup, run the
# keyless local option below; OpenAI remains a cloud option.
#
# Cloud (OpenAI): defaults target text-embedding-3-small (1536 dims).
EMBEDDINGS_API_KEY=
# EMBEDDINGS_BASE_URL=https://api.openai.com/v1
# EMBEDDINGS_MODEL=text-embedding-3-small
# EMBEDDINGS_DIMENSIONS=1536
# Overall request timeout (ms).
# EMBEDDINGS_TIMEOUT_MS=120000
#
# Local Ollama (recommended when you want fewer API keys — no key needed):
# Ollama's OpenAI-compatible endpoint is keyless, so set EMBEDDINGS_ENABLED=true
# instead of a key (mirrors SUMMARIZATION_ENABLED). `ollama pull nomic-embed-text`
# first. IMPORTANT: nomic-embed-text emits 768-dim vectors and the pgvector
# column dimension is frozen when the embeddings migration first runs — set
# EMBEDDINGS_DIMENSIONS=768 BEFORE the first `api:migrate`/boot. If the table
# already exists with a different dimension, a manual follow-up migration is
# needed to change it.
# EMBEDDINGS_ENABLED=true
# EMBEDDINGS_BASE_URL=http://localhost:11434/v1
# EMBEDDINGS_MODEL=nomic-embed-text
# EMBEDDINGS_DIMENSIONS=768

# --- Entity extraction (knowledge graph, JJ-32) ---
# After transcription, an LLM pulls the named things out of each recording
# (people, organizations, places, products, dates, amounts, ...) into a per-user
# registry — the seed of the knowledge graph. Any OpenAI-compatible
# /chat/completions endpoint works. Leave ENTITY_EXTRACTION_API_KEY empty to
# disable extraction entirely; defaults target DeepSeek (deepseek-chat). The
# relation, contact-resolution, duplicate-judge (below) providers all inherit
# these values unless overridden with their own prefix.
ENTITY_EXTRACTION_API_KEY=
# ENTITY_EXTRACTION_BASE_URL=https://api.deepseek.com/v1
# ENTITY_EXTRACTION_MODEL=deepseek-chat
# ENTITY_EXTRACTION_TIMEOUT_MS=120000
# Local Ollama (keyless): set ENTITY_EXTRACTION_ENABLED=true instead of a key.
# ENTITY_EXTRACTION_ENABLED=true
# ENTITY_EXTRACTION_BASE_URL=http://localhost:11434/v1
# ENTITY_EXTRACTION_MODEL=llama3.1

# --- Duplicate judge (entity reconciliation, JJ-63) ---
# When you reconcile two possibly-duplicate entities (e.g. "Foo" the
# organization vs "Foo" the product), an LLM judges whether they are the same
# real-world thing and which type/name to keep. Each ENTITY_JUDGE_* var falls
# back to its ENTITY_EXTRACTION_* equivalent, so wherever extraction runs the
# judge works with zero extra setup. Set these only to use a different (e.g.
# stronger) model for judging. Only entity names/types are sent — never
# transcripts.
# ENTITY_JUDGE_API_KEY=
# ENTITY_JUDGE_BASE_URL=https://api.deepseek.com/v1
# ENTITY_JUDGE_MODEL=deepseek-chat
# ENTITY_JUDGE_TIMEOUT_MS=60000
# ENTITY_JUDGE_ENABLED=true

# --- Web research for reconciliation (OPT-IN, OFF by default) ---
# When enabled, the duplicate judge may consult a web-grounded, OpenAI-compatible
# /chat/completions endpoint (e.g. Perplexity, or an OpenRouter web model) to
# help decide an ambiguous entity's real type. This is the ONLY entity feature
# that reaches the public web, so it is disabled unless WEB_RESEARCH_ENABLED=true
# AND a base URL + model are configured. PRIVACY: only the entity's name, type
# and a short "possibly the same as X" hint ever leave — never transcripts,
# audio, or your other entities. Users still confirm every merge by hand.
# WEB_RESEARCH_ENABLED=false
# WEB_RESEARCH_BASE_URL=https://api.perplexity.ai
# WEB_RESEARCH_MODEL=sonar
# WEB_RESEARCH_API_KEY=
# WEB_RESEARCH_TIMEOUT_MS=30000

# --- Speaker diarization (hosted pyannoteAI API) ---
# pyannoteai = diarization + cross-recording identity via voiceprints (default)
# off        = disabled
SPEAKER_ID_PROVIDER=pyannoteai
# API key from pyannote.ai. Audio is uploaded to pyannoteAI over HTTPS; your
# S3/MinIO is never exposed to the internet for this. New speakers are enrolled
# from clips sliced in-process with ffmpeg (the ffmpeg binary must be on PATH;
# the API Docker image ships it).
PYANNOTEAI_API_KEY=
# Model: precision-2 is required for speaker identification/voiceprints.
PYANNOTEAI_MODEL=precision-2
# Base URL (override only for a proxy/self-hosted gateway).
# PYANNOTEAI_BASE_URL=https://api.pyannote.ai/v1
# Minimum confidence (pyannoteAI's 0-100 scale) to accept a voiceprint match.
# 0 = always take the closest voiceprint regardless of confidence, which makes
# known speakers get matched into recordings they aren't in. 50 is pyannoteAI's
# recommended strict-matching floor; raise toward 70 for stricter matching.
# PYANNOTEAI_MATCH_THRESHOLD=50
# Minimum speaking seconds before a new speaker is auto-enrolled as a voiceprint.
# PYANNOTEAI_MIN_ENROLL_SECONDS=6
# Max seconds of audio used per enrollment voiceprint.
# PYANNOTEAI_VOICEPRINT_MAX_SECONDS=30
# Job poll interval and overall timeout (ms).
# PYANNOTEAI_POLL_INTERVAL_MS=3000
# PYANNOTEAI_TIMEOUT_MS=1800000

# --- Authentication (passkeys / WebAuthn) ---
# Domain the web app is served from; passkeys are cryptographically bound to
# it. 'localhost' for local dev, your real domain for deployments. WebAuthn
# needs a secure context (localhost or HTTPS).
AUTH_RP_ID=localhost
# Human-readable name shown in the passkey prompt.
AUTH_RP_NAME=Plaudern
# Comma-separated origins accepted in WebAuthn ceremonies and CORS. Empty =
# the localhost dev ports when AUTH_RP_ID=localhost, else https://<AUTH_RP_ID>.
AUTH_ORIGINS=
# Session cookie lifetime in days.
AUTH_SESSION_TTL_DAYS=30
# false = only existing accounts can sign in (the very first account can
# always be created).
AUTH_ALLOW_REGISTRATION=true
# true = restore the old unauthenticated single-user mode (all data belongs
# to the fixed default user). Only do this behind your own access control.
AUTH_DISABLED=false

# --- Encryption ---
# General-purpose key used to encrypt secrets stored in the database
# (currently the Plaud password, calendar feed URLs, and the email-in token).
APP_ENCRYPTION_SECRET=change-me

# --- Plaud cloud sync ---
# How often to poll the Plaud cloud for new recordings; 0 disables the poller.
PLAUD_POLL_INTERVAL_MS=300000

# --- Email-in (sources/email) ---
# Every user gets a personal inbox+<token>@<domain> address (token generated
# per-user from the settings page); forwarding anything to it becomes an inbox
# item, attachments included. Domain used to render that address — point your
# inbound mail relay (SES, Mailgun, Postmark, a self-hosted Postfix, ...) at
# this domain and configure it to POST to /api/v1/webhooks/email.
EMAIL_INBOUND_DOMAIN=
# Shared secret the inbound-parse webhook must present in the
# x-webhook-secret header. Required for the endpoint to accept mail at all —
# set it to whatever your relay is configured to send.
EMAIL_WEBHOOK_SECRET=change-me

# --- Notifications (outbound) ---
# The notification engine fans proactive notifications (briefings, nudges,
# digests, ...) out to the channels each user opted into. A channel with no
# server config simply reports "not configured" in the settings UI and is
# skipped — nothing errors.
#
# Web push: generate a key pair once with `npx web-push generate-vapid-keys`.
# Both keys unset = web push disabled.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI sent to push services (mailto: or https:), per the VAPID spec.
# VAPID_SUBJECT=mailto:admin@plaudern.local
#
# Email: any SMTP server/relay (Mailgun, SES, Postmark, your own, ...).
# SMTP_HOST unset = email notifications disabled. Delivery goes to the address
# each user sets in their notification settings (NOT the email-in address
# above — that one is inbound).
SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# Sender shown on outgoing mail.
# SMTP_FROM=Plaudern <notifications@plaudern.local>
# true = implicit TLS (usually port 465); false = STARTTLS. Defaults to true
# on port 465, false otherwise.
# SMTP_SECURE=false

# --- Calendar sync ---
# Subscribed feed URLs are encrypted with APP_ENCRYPTION_SECRET (above).
# How often to refresh subscribed calendar feeds (and re-run recording↔event
# auto-linking); 0 disables the poller.
CALENDAR_POLL_INTERVAL_MS=900000

# --- Native Google Calendar (optional) ---
# Leave unset to hide the feature in the UI.
# Register a Google Cloud OAuth "Web application" client and enable the Google Calendar API.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must exactly match the redirect URI registered in Google Cloud, pointing at the API callback:
GOOGLE_OAUTH_REDIRECT_URI=https://your-host/v1/calendar/google/callback
# Only if the web app is served from a different origin than the API (else leave empty):
GOOGLE_APP_BASE_URL=

# Google Cloud setup:
#  1. Google Cloud Console -> new/select project -> enable "Google Calendar API".
#  2. OAuth consent screen -> External -> add your Google account as a Test user.
#  3. Credentials -> Create OAuth client ID -> Web application.
#  4. Authorized redirect URI = the exact value of GOOGLE_OAUTH_REDIRECT_URI.
#  5. Copy the client ID/secret into the vars above and redeploy.

# --- Reverse geocoding ---
# nominatim = resolve GPS metadata to place names via the configured Nominatim
# server (note: sends note coordinates there — point NOMINATIM_URL at a
# self-hosted instance or set GEOCODER=off if that's a concern);
# stub = deterministic offline labels; off = disabled (UI shows raw coords)
GEOCODER=nominatim
NOMINATIM_URL=https://nominatim.openstreetmap.org
GEOCODER_USER_AGENT=plaudern/0.1 (self-hosted)

PORT=3000
