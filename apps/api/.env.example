# --- Database ---
DATABASE_DRIVER=postgres
DATABASE_URL=postgres://plaudern:plaudern@localhost:5432/plaudern
# set true for quick local dev to auto-create schema; leave unset to run migrations
DATABASE_SYNCHRONIZE=false

# --- Object storage (MinIO in dev) ---
STORAGE_DRIVER=s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=plaudern-inbox
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL=900

# --- Queue ---
QUEUE_DRIVER=bull
REDIS_URL=redis://localhost:6379

# --- Transcription ---
# stub = deterministic offline transcription; openai = real Whisper API
TRANSCRIPTION_PROVIDER=stub
TRANSCRIPTION_MODEL=whisper-1
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

PORT=3000
