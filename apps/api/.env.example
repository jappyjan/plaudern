# =============================================================================
# AI configuration has MOVED OUT OF ENV VARS.
#
# AI provider credentials and per-capability settings — summarization,
# transcription (ElevenLabs/Whisper), diarization (pyannoteAI), embeddings, OCR,
# and every LLM extractor (entities, topics, tasks, commitments, questions,
# facts, decisions, reminders, docmeta, chat, verification, journal, …) — are
# now configured PER USER inside the app, under **Settings → AI**:
#   1. Add a provider *connection* (name, protocol, base URL, API key).
#   2. Assign a provider + model to each capability.
# There are NO AI env vars any more. On upgrade from an older env-based install,
# the previous AI env is imported once into the DB at boot
# (AiConfigImportService) and owned by the pre-auth user, which the first
# registered account adopts.
#
# Future developers/agents: do NOT add new AI provider env vars. Register a new
# capability in the DB-backed registry instead — see libs/backend/ai-config.
#
# The one exception below (EMBEDDINGS_DIMENSIONS) is a deploy-time/infra setting,
# not a per-user credential.
# =============================================================================

# --- Database ---
DATABASE_DRIVER=postgres
DATABASE_URL=postgres://plaudern:plaudern@localhost:5432/plaudern
# set true for quick local dev to auto-create schema; leave unset to run migrations
DATABASE_SYNCHRONIZE=false

# --- Object storage (MinIO in dev) ---
STORAGE_DRIVER=s3
# Internal endpoint used for server-side S3 operations.
S3_ENDPOINT=http://localhost:9000
# Endpoint baked into presigned URLs handed to clients. Set to a host reachable
# by the client (e.g. your LAN IP) when uploading from a phone/simulator.
# Falls back to S3_ENDPOINT when unset.
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=plaudern-inbox
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL=900

# --- Queue ---
QUEUE_DRIVER=bull
REDIS_URL=redis://localhost:6379

# --- Embeddings vector dimension (infra, NOT a per-user AI setting) ---
# The pgvector column width is frozen the first time the embeddings table is
# created, so it must be known at migration time — hence it stays an env var.
# Set it to match the embedding model you'll configure in Settings → AI BEFORE
# the first `api:migrate`/boot (1536 = OpenAI text-embedding-3-small; 768 =
# nomic-embed-text). Changing it later needs a manual follow-up migration.
# EMBEDDINGS_DIMENSIONS=1536

# --- Authentication (passkeys / WebAuthn) ---
# Domain the web app is served from; passkeys are cryptographically bound to
# it. 'localhost' for local dev, your real domain for deployments. WebAuthn
# needs a secure context (localhost or HTTPS).
AUTH_RP_ID=localhost
# Human-readable name shown in the passkey prompt.
AUTH_RP_NAME=Plaudern
# Comma-separated origins accepted in WebAuthn ceremonies and CORS. Empty =
# the localhost dev ports when AUTH_RP_ID=localhost, else https://<AUTH_RP_ID>.
AUTH_ORIGINS=
# Session cookie lifetime in days.
AUTH_SESSION_TTL_DAYS=30
# false = only existing accounts can sign in (the very first account can
# always be created).
AUTH_ALLOW_REGISTRATION=true
# true = restore the old unauthenticated single-user mode (all data belongs
# to the fixed default user). Only do this behind your own access control.
AUTH_DISABLED=false

# --- Encryption ---
# General-purpose key used to encrypt secrets stored in the database (AI
# provider API keys, the Plaud password, calendar feed URLs, the email-in
# token). CHANGE THIS in production and keep it stable — rotating it makes
# previously-encrypted secrets undecryptable.
APP_ENCRYPTION_SECRET=change-me

# --- Plaud cloud sync ---
# How often to poll the Plaud cloud for new recordings; 0 disables the poller.
PLAUD_POLL_INTERVAL_MS=300000

# --- Email-in (sources/email) ---
# Every user gets a personal inbox+<token>@<domain> address (token generated
# per-user from the settings page); forwarding anything to it becomes an inbox
# item, attachments included. Domain used to render that address — point your
# inbound mail relay (SES, Mailgun, Postmark, a self-hosted Postfix, ...) at
# this domain and configure it to POST to /api/v1/webhooks/email.
EMAIL_INBOUND_DOMAIN=
# Shared secret the inbound-parse webhook must present in the
# x-webhook-secret header. Required for the endpoint to accept mail at all —
# set it to whatever your relay is configured to send.
EMAIL_WEBHOOK_SECRET=change-me

# --- Notifications (outbound) ---
# The notification engine fans proactive notifications (briefings, nudges,
# digests, ...) out to the channels each user opted into. A channel with no
# server config simply reports "not configured" in the settings UI and is
# skipped — nothing errors.
#
# Web push: generate a key pair once with `npx web-push generate-vapid-keys`.
# Both keys unset = web push disabled.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI sent to push services (mailto: or https:), per the VAPID spec.
# VAPID_SUBJECT=mailto:admin@plaudern.local
#
# Email: any SMTP server/relay (Mailgun, SES, Postmark, your own, ...).
# SMTP_HOST unset = email notifications disabled. Delivery goes to the address
# each user sets in their notification settings (NOT the email-in address
# above — that one is inbound).
SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# Sender shown on outgoing mail.
# SMTP_FROM=Plaudern <notifications@plaudern.local>
# true = implicit TLS (usually port 465); false = STARTTLS. Defaults to true
# on port 465, false otherwise.
# SMTP_SECURE=false

# --- Calendar sync ---
# Subscribed feed URLs are encrypted with APP_ENCRYPTION_SECRET (above).
# How often to refresh subscribed calendar feeds (and re-run recording↔event
# auto-linking); 0 disables the poller.
CALENDAR_POLL_INTERVAL_MS=900000

# --- Native Google Calendar (optional) ---
# Leave unset to hide the feature in the UI.
# Register a Google Cloud OAuth "Web application" client and enable the Google Calendar API.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must exactly match the redirect URI registered in Google Cloud, pointing at the API callback:
GOOGLE_OAUTH_REDIRECT_URI=https://your-host/v1/calendar/google/callback
# Only if the web app is served from a different origin than the API (else leave empty):
GOOGLE_APP_BASE_URL=

# Google Cloud setup:
#  1. Google Cloud Console -> new/select project -> enable "Google Calendar API".
#  2. OAuth consent screen -> External -> add your Google account as a Test user.
#  3. Credentials -> Create OAuth client ID -> Web application.
#  4. Authorized redirect URI = the exact value of GOOGLE_OAUTH_REDIRECT_URI.
#  5. Copy the client ID/secret into the vars above and redeploy.

# --- Reverse geocoding ---
# nominatim = resolve GPS metadata to place names via the configured Nominatim
# server (note: sends note coordinates there — point NOMINATIM_URL at a
# self-hosted instance or set GEOCODER=off if that's a concern);
# stub = deterministic offline labels; off = disabled (UI shows raw coords)
GEOCODER=nominatim
NOMINATIM_URL=https://nominatim.openstreetmap.org
GEOCODER_USER_AGENT=plaudern/0.1 (self-hosted)

PORT=3000
