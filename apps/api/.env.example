# --- Database ---
DATABASE_DRIVER=postgres
DATABASE_URL=postgres://plaudern:plaudern@localhost:5432/plaudern
# set true for quick local dev to auto-create schema; leave unset to run migrations
DATABASE_SYNCHRONIZE=false

# --- Object storage (MinIO in dev) ---
STORAGE_DRIVER=s3
# Internal endpoint used for server-side S3 operations.
S3_ENDPOINT=http://localhost:9000
# Endpoint baked into presigned URLs handed to clients. Set to a host reachable
# by the client (e.g. your LAN IP) when uploading from a phone/simulator.
# Falls back to S3_ENDPOINT when unset.
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=plaudern-inbox
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL=900

# --- Queue ---
QUEUE_DRIVER=bull
REDIS_URL=redis://localhost:6379

# --- Transcription (hosted ElevenLabs Scribe API, scribe_v2) ---
# Audio bytes are uploaded to ElevenLabs directly (we push, they never pull),
# so your storage stays private. API key from elevenlabs.io.
ELEVENLABS_API_KEY=
# Speech-to-text model. scribe_v1 is deprecated; use scribe_v2.
# ELEVENLABS_STT_MODEL=scribe_v2
# Base URL (override only for a proxy/self-hosted gateway).
# ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
# Tag non-speech sounds like (laughter) inline in the transcript.
# ELEVENLABS_TAG_AUDIO_EVENTS=false
# Overall request timeout and audio-download timeout (ms).
# ELEVENLABS_STT_TIMEOUT_MS=1800000
# ELEVENLABS_DOWNLOAD_TIMEOUT_MS=300000

# --- AI summarization ---
# After a recording is transcribed and diarized, an LLM writes it a short
# descriptive title and a Markdown summary (with mermaid diagrams and clickable
# speaker mentions), picking a layout that fits the content. Any
# OpenAI-compatible /chat/completions endpoint works. Leave SUMMARIZATION_API_KEY
# empty to disable summarization entirely (the pipeline step becomes a no-op and
# the UI just shows the transcript).
#
# Defaults target DeepSeek (deepseek-chat) — the cheapest capable option. For
# OpenAI use SUMMARIZATION_BASE_URL=https://api.openai.com/v1 and
# SUMMARIZATION_MODEL=gpt-4o-mini; OpenRouter, Together, Groq, or a local
# llama.cpp gateway work the same way.
SUMMARIZATION_API_KEY=
# SUMMARIZATION_BASE_URL=https://api.deepseek.com/v1
# SUMMARIZATION_MODEL=deepseek-chat
# Overall request timeout (ms).
# SUMMARIZATION_TIMEOUT_MS=120000

# --- Speaker diarization (hosted pyannoteAI API) ---
# pyannoteai = diarization + cross-recording identity via voiceprints (default)
# off        = disabled
SPEAKER_ID_PROVIDER=pyannoteai
# API key from pyannote.ai. Audio is uploaded to pyannoteAI over HTTPS; your
# S3/MinIO is never exposed to the internet for this. New speakers are enrolled
# from clips sliced in-process with ffmpeg (the ffmpeg binary must be on PATH;
# the API Docker image ships it).
PYANNOTEAI_API_KEY=
# Model: precision-2 is required for speaker identification/voiceprints.
PYANNOTEAI_MODEL=precision-2
# Base URL (override only for a proxy/self-hosted gateway).
# PYANNOTEAI_BASE_URL=https://api.pyannote.ai/v1
# Minimum confidence (pyannoteAI's 0-100 scale) to accept a voiceprint match.
# 0 = always take the closest voiceprint regardless of confidence, which makes
# known speakers get matched into recordings they aren't in. 50 is pyannoteAI's
# recommended strict-matching floor; raise toward 70 for stricter matching.
# PYANNOTEAI_MATCH_THRESHOLD=50
# Minimum speaking seconds before a new speaker is auto-enrolled as a voiceprint.
# PYANNOTEAI_MIN_ENROLL_SECONDS=6
# Max seconds of audio used per enrollment voiceprint.
# PYANNOTEAI_VOICEPRINT_MAX_SECONDS=30
# Job poll interval and overall timeout (ms).
# PYANNOTEAI_POLL_INTERVAL_MS=3000
# PYANNOTEAI_TIMEOUT_MS=1800000

# --- Authentication (passkeys / WebAuthn) ---
# Domain the web app is served from; passkeys are cryptographically bound to
# it. 'localhost' for local dev, your real domain for deployments. WebAuthn
# needs a secure context (localhost or HTTPS).
AUTH_RP_ID=localhost
# Human-readable name shown in the passkey prompt.
AUTH_RP_NAME=Plaudern
# Comma-separated origins accepted in WebAuthn ceremonies and CORS. Empty =
# the localhost dev ports when AUTH_RP_ID=localhost, else https://<AUTH_RP_ID>.
AUTH_ORIGINS=
# Session cookie lifetime in days.
AUTH_SESSION_TTL_DAYS=30
# false = only existing accounts can sign in (the very first account can
# always be created).
AUTH_ALLOW_REGISTRATION=true
# true = restore the old unauthenticated single-user mode (all data belongs
# to the fixed default user). Only do this behind your own access control.
AUTH_DISABLED=false

# --- Encryption ---
# General-purpose key used to encrypt secrets stored in the database
# (currently the Plaud password and calendar feed URLs).
APP_ENCRYPTION_SECRET=change-me

# --- Plaud cloud sync ---
# How often to poll the Plaud cloud for new recordings; 0 disables the poller.
PLAUD_POLL_INTERVAL_MS=300000

# --- Calendar sync ---
# Subscribed feed URLs are encrypted with APP_ENCRYPTION_SECRET (above).
# How often to refresh subscribed calendar feeds (and re-run recording↔event
# auto-linking); 0 disables the poller.
CALENDAR_POLL_INTERVAL_MS=900000

# --- Native Google Calendar (optional) ---
# Leave unset to hide the feature in the UI.
# Register a Google Cloud OAuth "Web application" client and enable the Google Calendar API.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must exactly match the redirect URI registered in Google Cloud. The API runs
# under the global prefix /api + URI versioning, so the callback path is
# /api/v1/calendar/google/callback (point it at whatever origin serves /api —
# for the bundled web+nginx image that's the web app's own domain):
GOOGLE_OAUTH_REDIRECT_URI=https://your-host/api/v1/calendar/google/callback
# Only if the web app is served from a different origin than the /api it calls
# (the bundled image proxies /api on the same origin, so leave this empty):
GOOGLE_APP_BASE_URL=

# Google Cloud setup:
#  1. Google Cloud Console -> new/select project -> enable "Google Calendar API".
#  2. OAuth consent screen -> External -> add your Google account as a Test user.
#  3. Credentials -> Create OAuth client ID -> Web application.
#  4. Authorized redirect URI = the exact value of GOOGLE_OAUTH_REDIRECT_URI.
#  5. Copy the client ID/secret into the vars above and redeploy.

# --- Reverse geocoding ---
# nominatim = resolve GPS metadata to place names via the configured Nominatim
# server (note: sends note coordinates there — point NOMINATIM_URL at a
# self-hosted instance or set GEOCODER=off if that's a concern);
# stub = deterministic offline labels; off = disabled (UI shows raw coords)
GEOCODER=nominatim
NOMINATIM_URL=https://nominatim.openstreetmap.org
GEOCODER_USER_AGENT=plaudern/0.1 (self-hosted)

PORT=3000
