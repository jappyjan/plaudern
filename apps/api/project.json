{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "tags": ["scope:backend", "type:app"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx watch apps/api/src/main.ts"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/api/tsconfig.json --outDir dist/apps/api"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/api/tsconfig.json --noEmit"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "jest --config apps/api/jest.config.js"
      }
    },
    "migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx node_modules/typeorm/cli.js migration:run -d libs/backend/persistence/src/data-source.ts"
      }
    },
    "seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx apps/api/src/seed.ts"
      }
    }
  }
}
